{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "cwd": "${workspaceFolder}",
            "args": [
                "runserver",
                "--noreload"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "DJANGO_SETTINGS_MODULE": "config.settings"
            },
            "django": true,
            "justMyCode": false
        }
    ]
}
